{
  "project": {
    "name": "MyLoveThaiHoc-Mobile",
    "version": "2.0.0",
    "description": "MyLoveThaiHoc - Personal mobile app (React Native + Expo)",
    "author": "Tiên Phong CDS"
  },

  "defaults": {
    "language": "vi",
    "timezone": "Asia/Ho_Chi_Minh",
    "draft_directory": ".claude/drafts",
    "template_directory": ".claude/templates"
  },

  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "type": "command",
        "command": "bash .claude/hooks/typecheck.sh",
        "timeout": 30
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Bash",
        "type": "command",
        "command": "bash .claude/hooks/pre-commit-check.sh",
        "timeout": 10
      }
    ]
  }
}
