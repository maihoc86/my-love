{
  "expo": {
    "name": "AI Love",
    "slug": "ai-love-mobile",
    "version": "2.0.0",
    "orientation": "portrait",
    "icon": "./assets/app-icon/app-icon.png",
    "userInterfaceStyle": "light",
    "scheme": "ailove",
    "splash": {
      "image": "./assets/splash-screen/splash-screen.png",
      "resizeMode": "contain",
      "backgroundColor": "#FFFBF5"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.tienphongcds.ailove"
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#FFFBF5",
        "foregroundImage": "./assets/android-icon-foreground.png",
        "backgroundImage": "./assets/android-icon-background.png",
        "monochromeImage": "./assets/android-icon-monochrome.png"
      },
      "package": "com.tienphongcds.ailove"
    },
    "web": {
      "favicon": "./assets/favicon/favicon.png",
      "bundler": "metro"
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      [
        "@rnmapbox/maps",
        {
          "RNMapboxMapsImpl": "mapbox",
          "RNMapboxMapsDownloadToken": "$MAPBOX_DOWNLOADS_TOKEN"
        }
      ]
    ]
  }
}
